PUBLIC_DATA_SERVICE_KEY=replace-with-data-go-kr-service-key
CRON_SECRET=replace-with-random-long-secret
PUBLIC_APP_URL=https://your-vercel-domain.vercel.app
EXPO_PUBLIC_LIBRARY_API_URL=https://your-vercel-domain.vercel.app/api/libraries

# AdMob 광고 단위 ID (앱 스토어 출시 빌드용, 개발 중에는 Test Ad 자동 사용)
# AdMob 콘솔 > 앱 > 광고 단위 에서 발급 (Android/iOS 각각 다름)
EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy
EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy
EXPO_PUBLIC_ADMOB_INTERSTITIAL_UNIT_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy
EXPO_PUBLIC_ADMOB_INTERSTITIAL_UNIT_ID_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy

# 스토어 스크린샷 촬영용 (안내 박스·배너 광고 숨김, 로컬 개발 전용)
# EXPO_PUBLIC_SCREENSHOT_MODE=true

# 개인정보 처리방침 URL (Play Store / App Store 제출 시 필수)
# 배포 후: https://your-vercel-domain.vercel.app/api/privacy
