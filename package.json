    "react-native-google-mobile-ads": "^16.3.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "~19.1.0",
    "@vercel/node": "^5.7.13",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20 <23"
